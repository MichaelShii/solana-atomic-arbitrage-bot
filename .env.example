# ============================================================
# MEVbot — Environment Variables Template
# ============================================================
# Quick start (dry-run only, no TX submitted):
#   cp .env.example .env
#   # Fill in SOLANA_RPC_URL and BOT_PRIVATE_KEY below — that's it
#   cargo build --release && ./target/release/mevbot
# ============================================================

# ── Required ────────────────────────────────────────────────

# Solana RPC endpoint. You MUST use your own private endpoint in production.
# The public api.mainnet-beta.solana.com is rate-limited and won't work for
# real trading. Use Helius, QuickNode, Shyft, Triton, or similar.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana WebSocket endpoint — required
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Your bot wallet private key (base58-encoded 64-byte keypair).
# Generate with: solana-keygen new --outfile ~/.config/solana/id.json
# Export with: solana config get keypair | xargs cat
BOT_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ── Optional ─────────────────────────────────────────────────

# Helius Sender for ultra-low-latency TX submission
# HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# Shyft Yellowstone gRPC x-token (if using gRPC for real-time pool state)
# SHYFT_API_KEY=YOUR_SHYFT_API_KEY

# ── Proxy (for users behind firewalls/VPNs; WSL/CN users) ───

# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# ── Environment switching ───────────────────────────────────

# Set to "devnet" to use config-devnet.toml + .env.devnet
# APP_ENV=devnet
