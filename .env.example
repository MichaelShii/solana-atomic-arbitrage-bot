# ============================================================
# MEVbot — Environment Variables Template
# Copy to .env and fill in your real values.
# DO NOT commit .env to version control.
# ============================================================

# ── Required ────────────────────────────────────────────────

# Solana RPC endpoint (HTTPS)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana WebSocket endpoint (WSS)
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Your bot wallet private key (base58-encoded 64-byte keypair)
BOT_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ── Helius Sender (optional, for low-latency TX submission) ──

# Helius API key for Sender authentication
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ── gRPC (optional) ─────────────────────────────────────────

# Shyft gRPC x-token (if using Yellowstone gRPC)
SHYFT_API_KEY=YOUR_SHYFT_API_KEY

# ── Proxy (optional, for WSL/CN users) ──────────────────────

# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# ── Environment switching ───────────────────────────────────

# Set to "devnet" to load config-devnet.toml + .env.devnet
# APP_ENV=devnet
